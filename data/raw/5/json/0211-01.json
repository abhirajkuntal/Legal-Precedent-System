    "opinions": [
      {
        "text": "ORDER\nPER CURIAM.\nAND NOW, this 27th day of September, 2010, the Application for Leave to File Original Process and the \u201cEmergency Extraordinary Relief Petition for Writ of Ha-beas Corpus,\u201d treated as a Petition for Writ of Habeas Corpus, are DISMISSED. See Commonwealth v. Reid, 537 Pa. 167, 642 A.2d 453 (1994) (hybrid representation is improper). The Prothonotary is directed to forward these filings to counsel of record.",
        "type": "majority",
        "author": "PER CURIAM."
      }
